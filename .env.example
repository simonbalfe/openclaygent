# ==============================================================
# API keys — the only thing most users touch. Paste and go.
# ==============================================================

# Required. One key drives any model (DeepSeek, Llama, Claude, GPT, Gemini...).
# Get one: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional. Paid search fallback after the free SearXNG rung; also lets you run
# with no Docker at all. Get one: https://dashboard.exa.ai/api-keys
EXA_API_KEY=exa-...

# Optional. Last search rung + the paid live fetch_page fallback (Tavily /extract).
TAVILY_API_KEY=tvly-...

# Optional. Enables the linkedin_* tools + the crunchbase_company fallback (Apify, per-item cost).
APIFY_API_TOKEN=apify_api_...

# Optional, advanced. Residential proxy + captcha solvers for the toughest bot-walled pages
# (patchright &proxy / &solve rungs). Read by docker-compose.
EVOMI_USERNAME=
EVOMI_PASSWORD=
EVOMI_GATEWAY=rp.evomi.com:1000
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=

# ==============================================================
# Advanced tuning — sane defaults, most users never touch these.
# Service URLs (SearXNG :8888, patchright :9223) are auto-defaulted in code;
# see docs/decisions.md to point elsewhere or disable a rung.
# ==============================================================

# Default OpenRouter model id (override per-run with --model).
OPENCLAY_MODEL=deepseek/deepseek-chat

# USD per Tavily credit for the cost report (Tavily bills in credits). 0.008 = pay-as-you-go rate.
TAVILY_USD_PER_CREDIT=0.008

# Apify actors — prefilled with working defaults, so `APIFY_API_TOKEN` alone is enough.
# Swap an id only to use a different scraper; the code falls back to these if unset.
APIFY_LINKEDIN_PROFILE_ACTOR=harvestapi~linkedin-profile-scraper
APIFY_LINKEDIN_POSTS_ACTOR=harvestapi~linkedin-profile-posts
APIFY_LINKEDIN_REACTIONS_ACTOR=harvestapi~linkedin-post-reactions
APIFY_LINKEDIN_EMPLOYEES_ACTOR=harvestapi~linkedin-company-employees
APIFY_LINKEDIN_COMPANY_ACTOR=harvestapi~linkedin-company
CRUNCHBASE_ACTOR=parseforge~crunchbase-scraper

# SearXNG container secret (compose defaults to openclaygent-local-dev).
SEARXNG_SECRET=

# HTTP API port (default 8080).
PORT=8080

# Postgres DSN for the cross-run L2 result cache. Unset = in-process cache only. See docs/decisions.md.
OPENCLAY_CACHE_URL=

# L2 cache TTL seconds (default 3600). Keep short — long TTLs serve stale web facts.
OPENCLAY_CACHE_TTL_SEC=3600
