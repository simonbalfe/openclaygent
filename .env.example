# One key to drive any model (DeepSeek, Llama, Claude, GPT, Gemini...)
OPENROUTER_API_KEY=sk-or-...

# Exa: the second search rung (after SearXNG). Search only — it is no longer a fetch_page
# fallback (its cache-first /contents conflicts with the live-data priority; see decisions.md).
# Key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=exa-...

# Optional: default OpenRouter model id. Override per-run in code.
OPENCLAY_MODEL=deepseek/deepseek-chat

# Advanced override — leave unset. The local SearXNG compose service (free, first search rung)
# is auto-used at http://localhost:8888. Only set this to point at a different host, or set it
# empty (SEARXNG_URL=) to disable the rung entirely.
# SEARXNG_URL=http://localhost:8888

# Tavily: last search rung (SearXNG → Exa → Tavily) AND the sole paid fetch_page fallback
# (Tavily /extract — always-live, runs after the free browser rungs)
TAVILY_API_KEY=tvly-...

# Optional: USD per Tavily credit, for the cost report (Tavily bills in credits, not dollars).
# Default 0.008 = the pay-as-you-go rate. Set to your plan's per-credit price for exact dollars.
TAVILY_USD_PER_CREDIT=0.008

# Advanced override — leave unset. The patchright rendered-fetch compose service is auto-used at
# http://localhost:9223 (fetch_page escalates here on JS-shell/blocked pages). Only set this to
# point elsewhere, or set it empty (PATCHRIGHT_URL=) to disable rendered fetch.
# PATCHRIGHT_URL=http://localhost:9223

# Optional: enables the linkedin_* tools AND the crunchbase_company fallback (Apify, per-item cost)
APIFY_API_TOKEN=apify_api_...

# Optional: override the Crunchbase actor used by crunchbase_company (default parseforge~crunchbase-scraper).
# Third-party actors change their I/O contract — swap here without touching code.
CRUNCHBASE_ACTOR=

# Optional: Evomi residential proxy rung for patchright (&proxy=1) — read by docker-compose
EVOMI_USERNAME=
EVOMI_PASSWORD=
EVOMI_GATEWAY=rp.evomi.com:1000

# Optional: captcha solve rungs for patchright (&solve=1) — read by docker-compose. Both share one
# anti-captcha-style JSON API; the solver ladder tries them in order, override per request with
# &solver=capsolver|twocaptcha. Token vendors (turnstile/hcaptcha/recaptcha) work on either; the
# full-page Cloudflare interstitial (AntiCloudflareTask, cookie return) is CapSolver-only.
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=

# Optional: SearXNG container secret (compose defaults to openclaygent-local-dev)
SEARXNG_SECRET=

# Optional: port for the HTTP API server (src/api.ts, default 8080)
PORT=8080

# Optional: Postgres DSN for the cross-run result cache (L2). Unset = in-process cache only
# (per-table, no persistence). When set, search + fetch results persist across runs/processes
# in an auto-created `openclay_cache` table. Default OFF preserves the live-not-stale default;
# turning it on is a deliberate freshness trade-off (see decisions.md, Per-table cache).
OPENCLAY_CACHE_URL=

# Optional: default TTL in seconds for L2 cache entries (default 3600 = 1h). Applies to
# successful results; dead URLs (404/410/401) are negative-cached on a fixed longer TTL.
# Keep this short — long TTLs serve stale web facts, which the live-verification stance avoids.
OPENCLAY_CACHE_TTL_SEC=3600
