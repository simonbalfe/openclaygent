# One key to drive any model (DeepSeek, Llama, Claude, GPT, Gemini...)
OPENROUTER_API_KEY=sk-or-...

# Exa: the second search rung (after SearXNG). Search only — it is no longer a fetch_page
# fallback (its cache-first /contents conflicts with the live-data priority; see decisions.md).
# Key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=exa-...

# Optional: default OpenRouter model id. Override per-run in code.
OPENCLAY_MODEL=deepseek/deepseek-chat

# Optional: route web_search through the local SearXNG compose service (free, first search rung)
SEARXNG_URL=http://localhost:8888

# Tavily: last search rung (SearXNG → Exa → Tavily) AND the sole paid fetch_page fallback
# (Tavily /extract — always-live, runs after the free browser rungs)
TAVILY_API_KEY=tvly-...

# Optional: USD per Tavily credit, for the cost report (Tavily bills in credits, not dollars).
# Default 0.008 = the pay-as-you-go rate. Set to your plan's per-credit price for exact dollars.
TAVILY_USD_PER_CREDIT=0.008

# Optional: patchright rendered-fetch compose service; fetch_page escalates here on JS-shell/block pages
PATCHRIGHT_URL=http://localhost:9223

# Optional: enables the linkedin_* tools (Apify HarvestAPI actors, costs per item)
APIFY_API_TOKEN=apify_api_...

# Optional: Evomi residential proxy rung for patchright (&proxy=1) — read by docker-compose
EVOMI_USERNAME=
EVOMI_PASSWORD=
EVOMI_GATEWAY=rp.evomi.com:1000

# Optional: CapSolver solve rung for patchright (&solve=1) — read by docker-compose
CAPSOLVER_API_KEY=

# Optional: SearXNG container secret (compose defaults to openclaygent-local-dev)
SEARXNG_SECRET=

# Optional: port for the HTTP API server (src/api.ts, default 8080)
PORT=8080
