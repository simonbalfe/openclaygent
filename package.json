{
  "name": "openclaygent",
  "version": "0.0.1",
  "description": "Open-source Claygent — a per-row web research agent. Brief in (target + prompt + schema), structured JSON out.",
  "type": "module",
  "module": "src/cli.ts",
  "private": true,
  "bin": {
    "openclaygent": "src/cli.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "cli": "bun run src/cli.ts",
    "api": "bun run src/api.ts",
    "api:dev": "bun --watch run src/api.ts",
    "test": "bun test",
    "test:e2e": "RUN_LIVE=1 bun test tests/e2e.test.ts",
    "knip": "knip-bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@mastra/core": "^1.41.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@scalar/hono-api-reference": "^0.11.3",
    "open-extract": "workspace:*",
    "open-search": "workspace:*",
    "zod": "^4.4.3",
    "zod-from-json-schema": "^0.5.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "knip": "^6.16.1",
    "typescript": "^5"
  }
}
